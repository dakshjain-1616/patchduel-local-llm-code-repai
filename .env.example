# ── Ollama (local inference) ──────────────────────────────────────────────────
# Ollama server URL — change if running Ollama on a remote host
OLLAMA_BASE_URL=http://localhost:11434

# Timeout (seconds) for code-repair API requests to Ollama
OLLAMA_TIMEOUT=120

# Timeout (seconds) for Ollama health-check / model-list requests
OLLAMA_HEALTH_TIMEOUT=5

# Default models to pre-select in the UI (must be pulled via: ollama pull <name>)
DEFAULT_MODEL_A=llama3.2
DEFAULT_MODEL_B=mistral-nemo

# ── OpenRouter (cloud inference) ──────────────────────────────────────────────
# Get a free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter API base URL (override only if proxying through a custom endpoint)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Timeout (seconds) for OpenRouter API requests
OPENROUTER_TIMEOUT=60

# Default cloud models for OpenRouter provider
DEFAULT_OPENROUTER_MODEL_A=openai/gpt-5.4-mini
DEFAULT_OPENROUTER_MODEL_B=mistralai/mistral-small-2603

# Optional branding sent in OpenRouter request headers
OPENROUTER_SITE_URL=https://github.com/dakshjain-1616/patchduel-local-llm-code-repair-arena
OPENROUTER_SITE_NAME=PatchDuel

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root or absolute)
DB_PATH=patchduel.db

# ── Gradio / App ──────────────────────────────────────────────────────────────
# Bind address for the Gradio server
APP_HOST=0.0.0.0

# Port for the Gradio server
APP_PORT=7860

# Set to "true" to create a public Gradio share link (requires internet)
GRADIO_SHARE=false

# ── Demo / offline mode ───────────────────────────────────────────────────────
# Set to "true" to skip all API calls and use deterministic mock responses.
# Useful for screenshots, CI, or environments without Ollama/OpenRouter.
DEMO_MODE=false
